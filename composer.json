{
  "name": "enzan-rocket/generator",
  "description": "Code Generator For Laravel Rocket",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Juyel",
      "email": "juyel@enzan-k.com"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/enzan-koubou/laravel-rocket-foundation"
    }
  ],
  "require": {
    "php": "^8.4",
    "symfony/yaml": "^7.0",
    "takaaki-mizuno/php-code-manipulator": "0.1.0",
    "takaaki-mizuno/swagger-parser": "0.1.0",
    "doctrine/dbal": "^4.4.3",
    "icanboogie/inflector": "^4.0.0",
    "nikic/php-parser": "^5.7.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1.8",
    "laravel/framework": "^13.8.0",
    "orchestra/testbench": "^11.0",
    "enzan-rocket/foundation": "dev-main",
    "friendsofphp/php-cs-fixer": "^3.95.1",
    "fakerphp/faker": "^1.24.1",
    "takaaki-mizuno/mwb-parser": "*"
  },
  "autoload": {
    "psr-4": {
      "EnzanRocket\\Generator\\": "src/"
    }
  },
  "autoload-dev": {
    "classmap": [
      "tests"
    ]
  }
}
