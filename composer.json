{
  "name": "enzan-rocket/generator",
  "description": "Code Generator For Laravel Rocket",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Takaaki Mizuno",
      "email": "takaaki.mizuno@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "symfony/yaml": "^7.0",
    "takaaki-mizuno/php-code-manipulator": "0.*",
    "takaaki-mizuno/swagger-parser": "0.*",
    "doctrine/dbal": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "icanboogie/inflector": "^2.0",
    "laravel/framework": "^13.0",
    "enzan-rocket/foundation": "*",
    "friendsofphp/php-cs-fixer": "^3.0",
    "fakerphp/faker": "^1.9",
    "nikic/PHP-Parser": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "EnzanRocket\\Generator\\": "src/"
    }
